@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

@* <h1>@ViewData["Title"]</h1> *@
<div class="container py-5">
    <div class="row justify-content-center">
        <!-- ローカルアカウントでのログイン -->
        <div class="col-md-6">
            <section class="mb-5">
                <form id="account" method="post" class="card shadow p-4">
                    <h2 class="text-center mb-4 text-brand">ログイン</h2>
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <label asp-for="Input.Email" class="form-label">メールアドレス</label>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                        <label asp-for="Input.Password" class="form-label">パスワード</label>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" asp-for="Input.RememberMe" id="rememberMe" />
                        <label asp-for="Input.RememberMe" class="form-check-label" for="rememberMe">
                            ログイン状態を保持する
                        </label>
                    </div>

                    <div class="mb-3">
                        <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-brand">ログイン</button>
                    </div>

                    <div class="text-center">
                        @* TODO: SendGrid等でメール送信を実装したら有効化する
                           現状はメール送信未設定のためパスワードリセット・確認メールが機能しない
                        <p><a id="forgot-password" asp-page="./ForgotPassword" class="text-decoration-none">パスワードを忘れた場合</a></p>
                        *@
                        <hr />
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" id="register-btn" class="w-100 btn btn-lg btn-outline-brand">
                            新規登録
                        </a>
                        @* TODO: 同上
                        <p class="mt-3"><a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="text-decoration-none">確認メールを再送信</a></p>
                        *@
                    </div>
                </form>
            </section>
        </div>

        @* TODO: GitHub OAuthログインを実装する
           メール重複（ローカルアカウントとの統合）の考慮が必要
        *@
    </div>
</div>
<footer>
    <p>&copy; 2025 shamshikie. All Rights Reserved.</p>
</footer>
<style>
</style>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}