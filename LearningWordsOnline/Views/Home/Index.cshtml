@{
    ViewData["Title"] = "Home";
}
<style>
    .hero-section {
        color: black;
    }

        .hero-section .highlight {
            color: #174b79;
        }

        .hero-section .btn-warning {
            color: #212529;
        }

        .hero-section p.small a {
            border-bottom: 1px solid transparent;
            transition: border-bottom 0.2s;
        }

            .hero-section p.small a:hover {
                border-bottom: 1px solid black;
            }

    .brand-title {
        color: #ff5733;
    }

    #gameCarousel {
        max-width: 800px;
        width: 90%;
    }

    .carousel-inner {
        aspect-ratio: 16/9;
        overflow: hidden;
        border: solid #ff5733 0.1rem;
    }

    .carousel-item {
        height: 100%;
    }

    .carousel-item img {
        height: 100%;
        object-fit: cover;
    }
</style>

<div class="hero-section text-center pt-5 mx-2 d-flex flex-column justify-content-center align-items-center">
    <h1 class="brand-title display-4 fw-bold mb-2">Wordify</h1>
    <h2 class="display-6 fw-bold mb-1">
        競って学べる<span class="highlight">対戦型英単語クイズアプリ</span>
    </h2>
    <p class="text-muted mb-4">Competitive English Word Battle — Learn While You Fight</p>

    <form asp-action="GuestLogin" asp-controller="Home" method="post" class="mb-2">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-lg fw-bold px-5 btn-brand">
            ゲストでプレイ <span class="badge bg-light text-dark ms-2" style="font-size:0.7rem;">登録不要</span>
        </button>
    </form>
    <a class="btn btn-lg fw-bold px-4 mb-2 btn-outline-brand" asp-area="Identity" asp-page="/Account/Register">
        新規登録
    </a>
    <p class="mt-1">
        アカウントをお持ちの方は
        <a class="text-brand fw-bold" asp-area="Identity" asp-page="/Account/Login">こちら</a>
    </p>
</div>

<!-- TODO: ゲームプレイのGIF/動画を追加する
     録画 → GIF変換 → wwwroot/images/demo/ に配置 → 下のカルーセルに差し替え -->

<!-- ゲーム画面のプレビュー -->
<div id="gameCarousel" class="carousel slide d-flex flex-column justify-content-center align-items-center mt-3 mx-auto mb-5" data-bs-ride="carousel">
    <div class="carousel-inner rounded-3 shadow-lg bg-light p-4">
        <div class="carousel-item active">
            <img src="~/images/demo/battle_demo.gif" class="d-block w-100" alt="バトルデモ">
        </div>
        <div class="carousel-item">
            <img src="~/images/demo/MyWordbook.png" class="d-block w-100" alt="ゲームプレイ画像1">
        </div>
        <div class="carousel-item">
            <img src="~/images/demo/Leaderboard.png" class="d-block w-100" alt="ゲームプレイ画像2">
        </div>
        <div class="carousel-item">
            <img src="~/images/demo/GameScreen.png" class="d-block w-100" alt="ゲームプレイ画像3">
        </div>
        <div class="carousel-item">
            <img src="~/images/demo/Friend.png" class="d-block w-100" alt="ゲームプレイ画像4">
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#gameCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#gameCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>
</div>

<footer>
    <p>&copy; 2025 Example Company. All Rights Reserved.</p>
</footer>
